---
import { Moon, BookOpen, Dumbbell } from '@lucide/astro';

const items = [
  {
    icon: Moon,
    iconBg: 'bg-secondary',
    iconColor: 'text-dark',
    time: '03.00 - 04.30',
    title: 'Qiyamullail & Doa',
    desc: 'Membangun kedekatan spiritual di sepertiga malam terakhir, dilanjutkan persiapan shalat Subuh.',
    rowClass: 'flex-row-reverse md:flex-row',
    align: '',
  },
  {
    icon: BookOpen,
    iconBg: 'bg-primary',
    iconColor: 'text-white',
    time: '04.30 - 06.30',
    title: 'Halaqah Tahfidz Pagi',
    desc: 'Ziyadah (menambah hafalan baru) dan murajaah hafalan bersama asatidzah.',
    rowClass: 'flex-row-reverse',
    align: 'md:text-right',
  },
  {
    icon: BookOpen,
    iconBg: 'bg-primary',
    iconColor: 'text-white',
    time: '07.30 - 12.00',
    title: 'Pendidikan Diniyah & Umum',
    desc: "Pembelajaran Ilmu Syar'i (Aqidah, Fiqh, Bahasa Arab) terintegrasi kurikulum nasional.",
    rowClass: 'flex-row-reverse md:flex-row',
    align: '',
  },
  {
    icon: Dumbbell,
    iconBg: 'bg-primary',
    iconColor: 'text-white',
    time: '16.00 - 17.30',
    title: 'Ekstrakurikuler & Olahraga',
    desc: 'Panahan, berenang, desain grafis, atau public speaking sesuai minat bakat santri.',
    rowClass: 'flex-row-reverse',
    align: 'md:text-right',
  },
];
---

<section class="py-24 bg-dark text-white">
  <div class="container mx-auto px-6 max-w-5xl">
    <div class="text-center mb-16 md:mb-20 reveal">
      <h2 class="text-3xl md:text-5xl font-serif text-white mb-6">Satu Hari di Ribath</h2>
      <p class="text-base md:text-lg text-white/60 max-w-2xl mx-auto">
        Rutinitas harian yang menyeimbangkan kebutuhan spiritual, intelektual, dan jasmani, membentuk
        kebiasaan pemenang.
      </p>
    </div>

    <div class="relative wrap overflow-hidden p-0 md:p-10 h-full">
      <!-- Vertical Line -->
      <div class="absolute border-opacity-20 border-white h-full border-l-2 left-[20px] md:left-1/2 md:-ml-1"></div>

      {
        items.map((item) => (
          <div
            class:list={[
              'mb-10 md:mb-12 flex justify-between items-center w-full reveal',
              item.rowClass,
            ]}
          >
            <div class="order-1 hidden md:block md:w-5/12"></div>
            <div
              class:list={[
                'z-20 flex items-center justify-center order-1 shadow-xl w-10 h-10 rounded-full ring-4 ring-dark shrink-0',
                item.iconBg,
              ]}
            >
              <item.icon class:list={['w-5 h-5', item.iconColor]} stroke-width={2} />
            </div>
            <div
              class:list={[
                'order-1 bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-5 md:p-6 w-[calc(100%-3.5rem)] md:w-5/12 ml-6 md:ml-0 hover:bg-white/10 transition-colors',
                item.align,
              ]}
            >
              <h3 class="font-serif font-bold text-secondary text-lg md:text-xl mb-1">{item.time}</h3>
              <h4 class="text-base md:text-lg font-medium text-white mb-2">{item.title}</h4>
              <p class="text-xs md:text-sm leading-snug text-white/70">{item.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
