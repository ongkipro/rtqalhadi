---
import {
  Menu,
  X,
  ArrowRight,
  ChevronRight,
  BookUser,
  GraduationCap,
  Building2,
  Images,
  ClipboardList,
  MapPin,
} from '@lucide/astro';
import { SITE, NAV, CONTACT, waLink } from '../data/site';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => path === href.replace(/\/$/, '');

// Ikon per menu untuk drawer mobile.
const NAV_ICONS: Record<string, any> = {
  '/profil': BookUser,
  '/program': GraduationCap,
  '/fasilitas': Building2,
  '/galeri': Images,
  '/ppdb': ClipboardList,
  '/kontak': MapPin,
};

const waPpdb = waLink(
  CONTACT.waPendaftaran.number,
  `Assalamualaikum, saya ingin bertanya tentang pendaftaran (PPDB) ${SITE.shortName}.`,
);
---

<header
  id="navbar"
  class="fixed w-full top-0 z-[60] transition-all duration-500 bg-transparent py-4 border-b border-transparent"
>
  <div class="container mx-auto px-6 max-w-7xl">
    <nav class="flex items-center justify-between" aria-label="Navigasi utama">
      <!-- Logo (teks saja) -->
      <a href="/" aria-label={`${SITE.shortName} — Beranda`} title="Beranda Ribath Al-Hadi" class="flex flex-col leading-none z-50 relative">
        <span id="nav-logo-text" class="font-serif font-bold text-xl md:text-2xl text-white transition-colors duration-300">
          {SITE.shortName}
        </span>
        <span id="nav-logo-sub" class="text-[10px] tracking-[0.2em] uppercase text-white/60 transition-colors duration-300 mt-0.5">
          {SITE.brandLine}
        </span>
      </a>

      <!-- Desktop Menu -->
      <div class="hidden lg:flex items-center gap-7">
        {
          NAV.map((item) => (
            <a
              href={item.href}
              title={item.label}
              class="nav-link text-sm font-medium text-white/90 transition-colors duration-300"
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <!-- CTA & Mobile Toggle -->
      <div class="flex items-center gap-3 relative z-50">
        <a
          href="/ppdb"
          title="Pendaftaran Santri Baru (PPDB)"
          class="hidden md:inline-flex items-center gap-1.5 pl-5 pr-4 py-2.5 text-sm font-medium text-white bg-primary rounded-full shadow-lg hover:bg-primary-dark transition-all duration-300 hover:-translate-y-0.5 group"
        >
          Daftar PPDB
          <ArrowRight class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" stroke-width={2} />
        </a>
        <button
          id="mobile-menu-btn"
          type="button"
          aria-label="Buka menu"
          aria-expanded="false"
          aria-controls="mobile-menu-drawer"
          aria-haspopup="dialog"
          class="lg:hidden text-white p-2 -mr-2 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 rounded-lg"
        >
          <Menu class="w-7 h-7" stroke-width={2} />
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- Mobile Menu — overlay + top sheet (turun dari atas).
     Di luar <header> agar tidak terjebak stacking context-nya. -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 bg-dark/60 backdrop-blur-sm z-[200] hidden opacity-0 transition-opacity duration-300"
>
</div>
<div
  id="mobile-menu-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Menu navigasi"
  inert
  class="fixed top-0 left-0 right-0 z-[210] bg-white shadow-2xl rounded-b-2xl transform -translate-y-full transition-transform duration-300 ease-in-out flex flex-col max-h-[90vh] overflow-y-auto"
>
  <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
    <span class="flex flex-col leading-none">
      <span class="font-serif font-bold text-xl text-primary">{SITE.shortName}</span>
      <span class="text-[10px] tracking-[0.2em] uppercase text-accent mt-0.5">{SITE.brandLine}</span>
    </span>
    <button
      id="close-menu-btn"
      type="button"
      aria-label="Tutup menu"
      class="text-dark p-2 bg-gray-100 rounded-full hover:bg-gray-200 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
    >
      <X class="w-6 h-6" stroke-width={2} />
    </button>
  </div>
  <div class="flex flex-col px-4 py-5 gap-1">
    {
      NAV.map((item) => {
        const Icon = NAV_ICONS[item.href] ?? BookUser;
        return (
          <a
            href={item.href}
            title={item.label}
            class="mobile-link stagger-item group flex items-center gap-4 rounded-2xl px-3 py-2.5 transition-colors hover:bg-cream"
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            <span class="nav-ico flex items-center justify-center w-11 h-11 rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary/15">
              <Icon class="w-5 h-5" stroke-width={1.75} />
            </span>
            <span class="nav-label flex-1 font-serif text-lg text-dark transition-colors group-hover:text-primary">
              {item.label}
            </span>
            <ChevronRight
              class="nav-chev w-5 h-5 text-accent/40 transition-all group-hover:text-primary group-hover:translate-x-0.5"
              stroke-width={2}
            />
          </a>
        );
      })
    }

    <a
      href="/ppdb"
      title="Pendaftaran Santri Baru (PPDB)"
      class="mobile-link stagger-item mt-3 px-6 py-4 inline-flex items-center justify-center gap-2 text-center text-base font-medium text-white bg-primary rounded-2xl shadow-lg hover:bg-primary-dark active:scale-[0.98] transition-all"
    >
      Daftar PPDB
      <ArrowRight class="w-5 h-5" stroke-width={2} />
    </a>

    <!-- Footer drawer: kontak cepat -->
    <div
      class="stagger-item mt-5 pt-5 border-t border-gray-100 flex items-center justify-between gap-3"
    >
      <div class="min-w-0">
        <p class="text-[11px] uppercase tracking-widest text-accent">Hubungi Kami</p>
        <p class="font-medium text-dark text-sm truncate">{CONTACT.waPendaftaran.display}</p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <a
          href={waPpdb}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Hubungi via WhatsApp"
          class="w-11 h-11 rounded-full bg-primary/10 text-primary flex items-center justify-center hover:bg-primary hover:text-white transition-colors"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
            <path
              d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.515 5.26l-.999 3.648 3.483-.913zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
            ></path>
          </svg>
        </a>
        <a
          href={CONTACT.instagram}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram @ribathalhadi"
          class="w-11 h-11 rounded-full bg-primary/10 text-primary flex items-center justify-center hover:bg-primary hover:text-white transition-colors"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.012-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  // 1. Efek scroll navbar (warna teks hanya untuk link desktop)
  const navbar = document.getElementById('navbar');
  const logoText = document.getElementById('nav-logo-text');
  const logoSub = document.getElementById('nav-logo-sub');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const desktopLinks = Array.from(document.querySelectorAll<HTMLElement>('.nav-link'));

  function onScroll() {
    if (!navbar) return;
    const solid = window.scrollY > 50;
    navbar.classList.toggle('bg-white/90', solid);
    navbar.classList.toggle('backdrop-blur-xl', solid);
    navbar.classList.toggle('shadow-sm', solid);
    navbar.classList.toggle('border-gray-200/50', solid);
    navbar.classList.toggle('py-3', solid);
    navbar.classList.toggle('bg-transparent', !solid);
    navbar.classList.toggle('py-4', !solid);
    navbar.classList.toggle('border-transparent', !solid);
    logoText?.classList.toggle('text-primary', solid);
    logoText?.classList.toggle('text-white', !solid);
    logoSub?.classList.toggle('text-accent', solid);
    logoSub?.classList.toggle('text-white/60', !solid);
    mobileBtn?.classList.toggle('text-dark', solid);
    mobileBtn?.classList.toggle('text-white', !solid);
    desktopLinks.forEach((link) => {
      // jangan timpa warna link yang sedang aktif (punya aria-current)
      if (link.hasAttribute('aria-current')) return;
      link.classList.toggle('text-dark', solid);
      link.classList.toggle('text-white/90', !solid);
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // 2. Mobile menu (a11y: aria, inert, Escape, focus trap)
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const closeMenuBtn = document.getElementById('close-menu-btn');
  const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
  const mobileMenuDrawer = document.getElementById('mobile-menu-drawer');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  function openMenu() {
    if (!mobileMenuOverlay || !mobileMenuDrawer) return;
    mobileMenuOverlay.classList.remove('hidden');
    void mobileMenuOverlay.offsetWidth;
    mobileMenuOverlay.classList.remove('opacity-0');
    mobileMenuDrawer.classList.remove('-translate-y-full');
    mobileMenuDrawer.classList.add('is-open');
    mobileMenuDrawer.removeAttribute('inert');
    document.body.style.overflow = 'hidden';
    mobileMenuBtn?.setAttribute('aria-expanded', 'true');
    mobileMenuBtn?.setAttribute('aria-label', 'Tutup menu');
    closeMenuBtn?.focus();
  }

  function closeMenu() {
    if (!mobileMenuOverlay || !mobileMenuDrawer) return;
    mobileMenuOverlay.classList.add('opacity-0');
    mobileMenuDrawer.classList.add('-translate-y-full');
    mobileMenuDrawer.classList.remove('is-open');
    mobileMenuDrawer.setAttribute('inert', '');
    document.body.style.overflow = '';
    mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    mobileMenuBtn?.setAttribute('aria-label', 'Buka menu');
    setTimeout(() => mobileMenuOverlay.classList.add('hidden'), 300);
    mobileMenuBtn?.focus();
  }

  mobileMenuBtn?.addEventListener('click', openMenu);
  closeMenuBtn?.addEventListener('click', closeMenu);
  mobileMenuOverlay?.addEventListener('click', closeMenu);
  mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenuDrawer && !mobileMenuDrawer.hasAttribute('inert')) {
      closeMenu();
    }
  });

  mobileMenuDrawer?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const focusables = mobileMenuDrawer.querySelectorAll<HTMLElement>('a[href], button');
    if (!focusables.length) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>
