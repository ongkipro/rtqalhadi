---
import { BookOpen, Menu, X } from '@lucide/astro';

const navItems = [
  { href: '#why-us', label: 'Tentang Kami' },
  { href: '#philosophy', label: 'Kurikulum' },
  { href: '#programs', label: 'Program' },
  { href: '#teachers', label: 'Asatidzah' },
  { href: '#facilities', label: 'Fasilitas' },
];
---

<header
  id="navbar"
  class="fixed w-full top-0 z-[60] transition-all duration-500 bg-transparent py-4 border-b border-transparent"
>
  <div class="container mx-auto px-6 max-w-7xl">
    <nav class="flex items-center justify-between">
      <!-- Logo -->
      <a href="#" class="flex items-center gap-2 group z-50 relative">
        <div
          class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white transition duration-300 group-hover:bg-secondary shadow-lg"
        >
          <BookOpen class="w-6 h-6" stroke-width={1.5} />
        </div>
        <span
          id="nav-logo-text"
          class="font-serif font-bold text-xl text-white transition-colors duration-300"
        >
          Al Hadi
        </span>
      </a>

      <!-- Desktop Menu -->
      <div class="hidden lg:flex items-center gap-8">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              data-nav-link
              class="text-sm font-medium text-white/90 hover:text-secondary transition duration-300"
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <!-- CTA & Mobile Toggle -->
      <div class="flex items-center gap-4 relative z-50">
        <a
          href="#admissions"
          class="hidden md:inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-white bg-primary rounded-full shadow-lg hover:bg-primary-dark transition-all duration-300 hover:-translate-y-0.5"
        >
          Daftar PPDB
        </a>
        <button
          id="mobile-menu-btn"
          aria-label="Toggle Menu"
          class="lg:hidden text-white hover:text-secondary p-2 -mr-2 transition-colors focus:outline-none focus:ring-2 focus:ring-white/50 rounded-lg"
        >
          <Menu class="w-7 h-7" stroke-width={2} />
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu Overlay & Drawer -->
  <div
    id="mobile-menu-overlay"
    class="fixed inset-0 bg-dark/60 backdrop-blur-sm z-[100] hidden opacity-0 transition-opacity duration-300"
  >
  </div>
  <div
    id="mobile-menu-drawer"
    class="fixed top-0 right-0 bottom-0 w-[80vw] max-w-sm bg-white z-[101] transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col shadow-2xl"
  >
    <div class="flex items-center justify-between p-6 border-b border-gray-100">
      <span class="font-serif font-bold text-xl text-primary">Menu</span>
      <button
        id="close-menu-btn"
        aria-label="Close Menu"
        class="text-dark p-2 bg-gray-100 rounded-full hover:bg-gray-200 transition-colors focus:outline-none"
      >
        <X class="w-6 h-6" stroke-width={2} />
      </button>
    </div>
    <div class="flex flex-col px-6 py-8 gap-6 overflow-y-auto">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="mobile-link text-xl font-serif text-dark hover:text-primary transition-colors"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="#admissions"
        class="mobile-link mt-4 px-6 py-4 text-center text-lg font-medium text-white bg-primary rounded-xl shadow-lg"
      >
        Daftar PPDB
      </a>
    </div>
  </div>
</header>
