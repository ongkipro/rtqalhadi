---
import { ArrowRight } from '@lucide/astro';
import { GALLERY } from '../data/content';

const base =
  'rounded-2xl overflow-hidden relative group bg-gray-200';
const images = GALLERY.slice(0, 5).map((item, i) => ({
  src: item.src,
  alt: item.alt,
  wrapper: i === 0 ? `col-span-2 row-span-2 ${base}` : base,
  overlay: i === 0,
}));
---

<section id="gallery" class="py-16 md:py-24 bg-cream">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16 reveal">
      <h2 class="text-3xl md:text-4xl font-serif text-dark mb-4">Kehidupan di Ribath</h2>
      <p class="text-accent">
        Momen-momen berharga dalam perjalanan menuntut ilmu di lingkungan yang asri dan kondusif.
      </p>
    </div>

    <!-- Modern Grid/Masonry layout -->
    <div
      class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-6 auto-rows-[150px] md:auto-rows-[200px] reveal delay-200"
    >
      {
        images.map((image) => (
          <div class={image.wrapper}>
            <img
              src={image.src}
              loading="lazy"
              decoding="async"
              alt={image.alt}
              title={image.alt}
              class="w-full h-full object-cover group-hover:scale-105 transition duration-700 cursor-pointer"
            />
            {image.overlay && (
              <div class="absolute inset-0 bg-dark/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" />
            )}
          </div>
        ))
      }
    </div>

    <div class="text-center mt-12 md:mt-16 reveal delay-300">
      <a
        href="/galeri"
        title="Galeri Kegiatan"
        class="inline-flex items-center gap-2 text-primary font-medium hover:text-secondary transition-colors group"
      >
        Lihat Galeri Lengkap
        <ArrowRight
          class="w-5 h-5 transform group-hover:translate-x-1 transition-transform"
          stroke-width={2}
        />
      </a>
    </div>
  </div>
</section>
