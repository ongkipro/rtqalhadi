---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
  invert?: boolean;
  class?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  align = 'center',
  invert = false,
  class: className = '',
} = Astro.props;

const wrap = align === 'center' ? 'text-center max-w-3xl mx-auto' : 'max-w-2xl';
const titleColor = invert ? 'text-white' : 'text-dark';
const subColor = invert ? 'text-white/60' : 'text-accent';
---

<div class:list={[wrap, 'reveal', className]}>
  {
    eyebrow && (
      <span class="text-secondary font-medium tracking-widest uppercase text-sm mb-4 block">
        {eyebrow}
      </span>
    )
  }
  <h2 class:list={['text-3xl md:text-5xl font-serif mb-6 leading-tight', titleColor]}>
    {title}
  </h2>
  {subtitle && <p class:list={['text-base md:text-lg', subColor]}>{subtitle}</p>}
</div>
