---
import { CirclePlay } from '@lucide/astro';
---

<section
  class="relative min-h-[100svh] flex items-center justify-center pt-32 pb-32 md:pb-40 overflow-hidden"
>
  <!-- Background Video/Image Placeholder -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1584551246679-0daf3d275d0f?auto=format&fit=crop&q=80&w=2000"
      alt="Islamic Architecture"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-dark/60 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-dark/90 via-dark/40 to-dark/60"></div>
  </div>

  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    <div class="max-w-4xl mx-auto text-center reveal">
      <!-- Eyebrow -->
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 mb-8"
      >
        <span class="flex h-2 w-2 rounded-full bg-secondary"></span>
        <span class="text-xs font-medium text-white tracking-widest uppercase"
          >Penerimaan Santri Baru Dibuka</span
        >
      </div>

      <!-- Main Headline -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-serif font-medium text-white leading-tight mb-8">
        Menjaga Al-Qur'an.<br />
        <span class="italic text-secondary">Membentuk Akhlak.</span><br />
        Menyiapkan Pemimpin Muslimah Masa Depan.
      </h1>

      <!-- Subheadline -->
      <p class="text-base md:text-xl text-white/80 font-light max-w-2xl mx-auto mb-12 px-4 md:px-0">
        Lembaga pendidikan Islam premium yang memadukan kedalaman spiritual, tahfidz Al-Qur'an mutqin,
        dan kepemimpinan modern.
      </p>

      <!-- Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#admissions"
          class="w-full sm:w-auto px-8 py-4 text-base font-medium text-primary bg-secondary rounded-full shadow-[0_0_40px_rgba(212,175,55,0.4)] hover:bg-white hover:text-primary transition-all duration-300 hover:-translate-y-1"
        >
          Daftar PPDB Sekarang
        </a>
        <a
          href="#gallery"
          class="w-full sm:w-auto px-8 py-4 text-base font-medium text-white bg-white/10 backdrop-blur-md rounded-full border border-white/20 hover:bg-white/20 transition-all duration-300 flex items-center justify-center gap-2"
        >
          <CirclePlay class="w-5 h-5" stroke-width={1.5} />
          Virtual Tour
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div
    class="absolute bottom-24 md:bottom-32 left-1/2 transform -translate-x-1/2 z-10 hidden md:flex flex-col items-center gap-2 opacity-70 hover:opacity-100 transition-opacity"
  >
    <span class="text-xs text-white uppercase tracking-widest">Scroll</span>
    <div class="w-[1px] h-12 bg-white/30 overflow-hidden relative">
      <div class="w-full h-1/2 bg-white absolute top-0 animate-[scroll-down_1.5s_ease-in-out_infinite]"></div>
    </div>
  </div>
</section>
