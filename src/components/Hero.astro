---
import { MessageCircle } from '@lucide/astro';
import { SITE, CONTACT, waLink } from '../data/site';

const waHref = waLink(
  CONTACT.waPendaftaran.number,
  'Assalamualaikum, saya ingin bertanya tentang pendaftaran santri baru Ribath Al-Hadi.',
);
---

<section class="relative min-h-[100svh] flex items-center justify-center pt-32 pb-36 md:pb-44 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/gallery/halaman-apel-gunung.webp"
      alt="Halaman Ribath Al-Hadi dengan latar Gunung Banyak"
      fetchpriority="high"
      decoding="async"
      class="w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-dark/60 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-dark/90 via-dark/40 to-dark/70"></div>
  </div>

  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    <div class="max-w-4xl mx-auto text-center reveal">
      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 mb-8">
        <span class="flex h-2 w-2 rounded-full bg-secondary animate-pulse"></span>
        <span class="text-xs font-medium text-white tracking-widest uppercase">Penerimaan Santri Baru — Kuota Terbatas</span>
      </div>

      <!-- Headline -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-serif font-medium text-white leading-tight mb-8">
        Rumah Kedua<br />
        <span class="italic text-secondary">Para Penghafal</span> Al-Qur'an.
      </h1>

      <!-- Subheadline -->
      <p class="text-base md:text-xl text-white/80 font-light max-w-2xl mx-auto mb-10 px-4 md:px-0">
        {SITE.type} di kaki Gunung Banyak, Pujon — Malang. Bagian dari keluarga besar Ma'had Nurul
        Haromain (cabang ke-66), dengan bimbingan tahfidz intensif dan akhlak Qur'ani.
      </p>

      <!-- Motto -->
      <div class="flex items-center justify-center gap-3 mb-10 text-white/70 text-sm tracking-widest uppercase">
        {
          SITE.motto.map((m, i) => (
            <>
              {i > 0 && <span class="text-secondary">•</span>}
              <span>{m}</span>
            </>
          ))
        }
      </div>

      <!-- Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/ppdb" class="w-full sm:w-auto px-8 py-4 text-base font-medium text-primary bg-secondary rounded-full shadow-[0_0_40px_rgba(212,175,55,0.4)] hover:bg-white hover:text-primary transition-all duration-300 hover:-translate-y-1">
          Daftar PPDB Sekarang
        </a>
        <a href={waHref} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto px-8 py-4 text-base font-medium text-white bg-white/10 backdrop-blur-md rounded-full border border-white/20 hover:bg-white/20 transition-all duration-300 flex items-center justify-center gap-2">
          <MessageCircle class="w-5 h-5" stroke-width={1.5} />
          Hubungi via WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>
