---
import { CONTACT, waLink } from '../data/site';

const waHref = waLink(
  CONTACT.waPendaftaran.number,
  'Assalamualaikum, saya ingin bertanya tentang Ribath Al-Hadi.'
);
---

<section id="cta" class="relative py-20 md:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/gallery/gedung-asrama-depan.webp"
      loading="lazy"
      decoding="async"
      alt="Gedung asrama putri Ribath Al-Hadi"
      title="Gedung asrama putri Ribath Al-Hadi"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-primary/90 mix-blend-multiply"></div>
  </div>

  <div class="container mx-auto px-6 max-w-4xl relative z-10 text-center reveal">
    <h2 class="text-3xl md:text-5xl lg:text-6xl font-serif text-white mb-6 md:mb-8 leading-tight">
      Investasi Terbaik untuk Putri Anda adalah Masa Depan Qur'ani.
    </h2>
    <p class="text-base md:text-lg text-white/80 mb-10 md:mb-12">
      Jangan lewatkan kesempatan menjadi bagian dari keluarga besar Ribath Al-Hadi. Kuota
      pendaftaran sangat terbatas untuk menjaga kualitas bimbingan dan tahfidz setiap santri.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/ppdb"
        title="Pendaftaran Santri Baru (PPDB)"
        class="w-full sm:w-auto px-8 py-4 md:px-10 md:py-5 text-base md:text-lg font-medium text-primary-dark bg-secondary rounded-full shadow-[0_0_40px_rgba(212,175,55,0.4)] hover:bg-white hover:text-primary transition-all duration-300 hover:-translate-y-1"
      >
        Daftar PPDB
      </a>
      <a
        href={waHref}
        target="_blank"
        rel="noopener noreferrer"
        title="Hubungi via WhatsApp"
        class="w-full sm:w-auto px-8 py-4 md:px-10 md:py-5 text-base md:text-lg font-medium text-white bg-green-500 rounded-full shadow-lg hover:bg-green-400 transition-all duration-300 flex items-center justify-center gap-2 hover:-translate-y-1"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12.01 2.013c-5.506 0-9.974 4.469-9.974 9.974 0 1.764.462 3.483 1.336 4.996L1.895 22.11l5.247-1.376a9.976 9.976 0 004.868 1.258h.004c5.505 0 9.973-4.468 9.973-9.973 0-5.505-4.468-9.974-9.973-9.974h-.004zm0 18.232h-.003a8.271 8.271 0 01-4.22-1.16l-.303-.18-3.136.822.836-3.056-.197-.314a8.271 8.271 0 01-1.265-4.387c0-4.57 3.718-8.288 8.288-8.288 4.57 0 8.288 3.718 8.288 8.288 0 4.57-3.718 8.288-8.288 8.288z"
          ></path>
          <path
            d="M16.632 13.916c-.254-.127-1.498-.74-1.732-.824-.233-.085-.403-.127-.573.127-.17.254-.658.824-.807.994-.148.17-.297.191-.551.064-.254-.127-1.07-.395-2.039-1.258-.755-.672-1.265-1.503-1.413-1.757-.148-.254-.016-.391.111-.518.114-.114.254-.297.381-.445.127-.148.17-.254.254-.424.085-.17.042-.318-.021-.445-.064-.127-.573-1.382-.784-1.892-.206-.496-.414-.428-.573-.436-.148-.008-.318-.008-.488-.008-.17 0-.445.064-.679.318-.233.254-.89.87-.89 2.122 0 1.252.912 2.461 1.039 2.631.127.17 1.794 2.738 4.343 3.836.607.262 1.082.419 1.45.537.608.194 1.163.167 1.6.101.488-.073 1.498-.612 1.71-1.204.212-.592.212-1.098.148-1.204-.064-.106-.233-.17-.487-.297z"
          ></path>
        </svg>
        Tanya via WhatsApp
      </a>
    </div>
  </div>
</section>
