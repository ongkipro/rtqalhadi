---
import { MapPin, Phone, AtSign, Map } from '@lucide/astro';
import { SITE, ADDRESS, CONTACT, NAV, mapEmbedSrc, mapLink, waLink } from '../data/site';

const year = 2026;
const waHref = waLink(CONTACT.waPendaftaran.number, 'Assalamualaikum, saya ingin bertanya tentang pendaftaran Ribath Al-Hadi.');
---

<footer class="bg-dark pt-16 md:pt-20 pb-24 sm:pb-10 text-white/70">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-12 mb-12 md:mb-16">
      <!-- Branding -->
      <div>
        <a href="/" class="flex flex-col leading-none mb-5">
          <span class="font-serif font-bold text-2xl text-white">{SITE.shortName}</span>
          <span class="text-[10px] tracking-[0.2em] uppercase text-white/50 mt-1">{SITE.brandLine}</span>
        </a>
        <p class="text-sm mb-5 leading-relaxed">{SITE.tagline}</p>
        <div class="flex flex-wrap gap-2 mb-6">
          {
            SITE.motto.map((m) => (
              <span class="text-[11px] font-medium uppercase tracking-wider text-secondary/90 bg-secondary/10 border border-secondary/20 rounded-full px-3 py-1">
                {m}
              </span>
            ))
          }
        </div>
        <div class="flex gap-3">
          <a href={CONTACT.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram @ribathalhadi" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-primary transition-colors">
            <AtSign class="w-5 h-5" stroke-width={2} />
          </a>
          <a href={CONTACT.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook Nurul Haromain Pujon" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>
          </a>
          <a href={waHref} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.01 2.013c-5.506 0-9.974 4.469-9.974 9.974 0 1.764.462 3.483 1.336 4.996L1.895 22.11l5.247-1.376a9.976 9.976 0 004.868 1.258h.004c5.505 0 9.973-4.468 9.973-9.973 0-5.505-4.468-9.974-9.973-9.974h-.004zm0 18.232h-.003a8.271 8.271 0 01-4.22-1.16l-.303-.18-3.136.822.836-3.056-.197-.314a8.271 8.271 0 01-1.265-4.387c0-4.57 3.718-8.288 8.288-8.288 4.57 0 8.288 3.718 8.288 8.288 0 4.57-3.718 8.288-8.288 8.288z"></path><path d="M16.632 13.916c-.254-.127-1.498-.74-1.732-.824-.233-.085-.403-.127-.573.127-.17.254-.658.824-.807.994-.148.17-.297.191-.551.064-.254-.127-1.07-.395-2.039-1.258-.755-.672-1.265-1.503-1.413-1.757-.148-.254-.016-.391.111-.518.114-.114.254-.297.381-.445.127-.148.17-.254.254-.424.085-.17.042-.318-.021-.445-.064-.127-.573-1.382-.784-1.892-.206-.496-.414-.428-.573-.436-.148-.008-.318-.008-.488-.008-.17 0-.445.064-.679.318-.233.254-.89.87-.89 2.122 0 1.252.912 2.461 1.039 2.631.127.17 1.794 2.738 4.343 3.836.607.262 1.082.419 1.45.537.608.194 1.163.167 1.6.101.488-.073 1.498-.612 1.71-1.204.212-.592.212-1.098.148-1.204-.064-.106-.233-.17-.487-.297z"></path></svg>
          </a>
        </div>
      </div>

      <!-- Navigasi -->
      <div>
        <h4 class="text-white font-serif font-medium mb-6">Navigasi</h4>
        <ul class="space-y-3">
          {NAV.map((item) => (
            <li><a href={item.href} class="hover:text-white transition-colors">{item.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Hubungi Kami -->
      <div>
        <h4 class="text-white font-serif font-medium mb-6">Hubungi Kami</h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <MapPin class="w-5 h-5 mt-1 shrink-0" stroke-width={2} />
            <span class="text-sm">{ADDRESS.building}</span>
          </li>
          <li class="flex items-center gap-3">
            <Phone class="w-5 h-5 shrink-0" stroke-width={2} />
            <a href={waHref} class="text-sm hover:text-white transition-colors">{CONTACT.waPendaftaran.display} <span class="text-white/40">(Pendaftaran)</span></a>
          </li>
          <li class="flex items-center gap-3">
            <AtSign class="w-5 h-5 shrink-0" stroke-width={2} />
            <a href={CONTACT.instagram} target="_blank" rel="noopener noreferrer" class="text-sm hover:text-white transition-colors">@ribathalhadi</a>
          </li>
        </ul>
      </div>

      <!-- Lokasi (Google Maps embed) -->
      <div class="flex flex-col gap-3">
        <div class="h-44 md:h-48 rounded-2xl border border-white/10 overflow-hidden bg-white/5">
          <iframe
            title={`Lokasi ${SITE.name}`}
            src={mapEmbedSrc}
            class="w-full h-full"
            style="border:0; filter: grayscale(0.2) contrast(1.05);"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
        <a href={mapLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-white/70 hover:text-white transition-colors">
          <Map class="w-4 h-4" stroke-width={2} />
          Buka di Google Maps
        </a>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
      <p class="text-center md:text-left">&copy; {year} {SITE.name}. Cabang {SITE.cabang}.</p>
      <div class="flex gap-4">
        <a href="/ppdb" class="hover:text-white transition-colors">PPDB</a>
        <a href="/kontak" class="hover:text-white transition-colors">Kontak</a>
        <a href={CONTACT.websiteInduk} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Nurul Haromain</a>
      </div>
    </div>
  </div>
</footer>
