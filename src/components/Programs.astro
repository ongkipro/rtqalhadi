---
import { ArrowRight, ChevronRight } from '@lucide/astro';

const programs = [
  {
    img: 'https://images.unsplash.com/photo-1542621323-22ea89104db6?auto=format&fit=crop&q=80&w=800',
    alt: 'Tahfidz',
    title: "Tahfidzul Qur'an",
    desc: 'Target hafalan 30 Juz bersanad muttasil, dilengkapi dengan pemahaman tajwid dan tafsir dasar.',
    delay: 'delay-100',
  },
  {
    img: 'https://images.unsplash.com/photo-1577985051167-0d49eec21977?auto=format&fit=crop&q=80&w=800',
    alt: 'Kitab Turats',
    title: 'Dirosah Islamiyah',
    desc: "Kajian kitab kuning (Turats) berjenjang meliputi Aqidah, Fiqh Syafi'i, Hadits, dan Bahasa Arab aktif.",
    delay: 'delay-200',
  },
  {
    img: 'https://images.unsplash.com/photo-1515187029135-18ee286d815b?auto=format&fit=crop&q=80&w=800',
    alt: 'Leadership',
    title: 'Muslimah Leadership',
    desc: 'Pengembangan soft-skills, public speaking, dan literasi digital untuk dakwah modern.',
    delay: 'delay-300',
  },
];
---

<section id="programs" class="py-24 bg-cream">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-16 gap-6 reveal">
      <div class="max-w-2xl">
        <span class="text-secondary font-medium tracking-widest uppercase text-sm mb-4 block"
          >Program Unggulan</span
        >
        <h2 class="text-3xl md:text-5xl font-serif text-dark leading-tight">
          Kurikulum Komprehensif Berbasis Karakter.
        </h2>
      </div>
      <a
        href="#admissions"
        class="inline-flex items-center gap-2 text-primary font-medium hover:text-secondary transition-colors group"
      >
        Lihat Selengkapnya
        <ArrowRight
          class="w-5 h-5 transform group-hover:translate-x-1 transition-transform"
          stroke-width={2}
        />
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-6 md:gap-8">
      {
        programs.map((program) => (
          <div
            class:list={[
              'group bg-white rounded-[2rem] overflow-hidden shadow-sm hover:shadow-premium transition-all duration-300 reveal',
              program.delay,
            ]}
          >
            <div class="aspect-video relative overflow-hidden bg-gray-200">
              <img
                src={program.img}
                loading="lazy"
                alt={program.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-dark/60 to-transparent opacity-60" />
            </div>
            <div class="p-6 md:p-8">
              <h3 class="text-xl md:text-2xl font-serif text-dark mb-3">{program.title}</h3>
              <p class="text-accent text-sm leading-relaxed mb-6">{program.desc}</p>
              <a
                href="#"
                class="text-primary font-medium text-sm hover:text-secondary transition-colors flex items-center gap-1"
              >
                Pelajari
                <ChevronRight class="w-4 h-4" stroke-width={2} />
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
