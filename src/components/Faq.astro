---
import { ChevronDown } from '@lucide/astro';
import { FAQS } from '../data/content';

const faqs = FAQS;
---

<section class="py-16 md:py-24 bg-white">
  <div class="container mx-auto px-6 max-w-3xl">
    <h2 class="text-3xl md:text-4xl font-serif text-center text-dark mb-12 reveal">
      Pertanyaan yang Sering Diajukan
    </h2>

    <div class="space-y-4 reveal delay-200">
      {
        faqs.map((faq) => (
          <div class="bg-cream rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <button class="faq-btn w-full px-6 py-5 text-left flex justify-between items-center focus:outline-none">
              <span class="font-medium text-dark pr-4">{faq.q}</span>
              <ChevronDown
                class="w-5 h-5 text-primary shrink-0 transform transition-transform duration-300"
                stroke-width={2}
              />
            </button>
            <div class="faq-content hidden px-6 pb-5 text-accent text-sm leading-relaxed border-t border-gray-100/50 pt-4">
              {faq.a}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
