---
import { BookOpen, Sparkles, Building2, Mountain } from '@lucide/astro';
import SectionHeading from './SectionHeading.astro';

const features = [
  {
    icon: BookOpen,
    title: 'Tahfidz Terbimbing',
    desc: 'Setoran hafalan dan muroja’ah harian (bin nadhri & bil hifdhi) langsung bersama para ustadzah.',
    delay: 'delay-100',
  },
  {
    icon: Sparkles,
    title: 'Khusus Putri',
    desc: 'Lingkungan asrama khusus muslimah yang aman, terjaga, dan nyaman untuk tumbuh dan menghafal.',
    delay: 'delay-200',
  },
  {
    icon: Building2,
    title: 'Naungan Nurul Haromain',
    desc: 'Cabang ke-66 Ma’had Nurul Haromain Pujon, dengan sanad keilmuan dari KH Ihya’ Ulumiddin.',
    delay: 'delay-300',
  },
  {
    icon: Mountain,
    title: 'Lingkungan Sejuk',
    desc: 'Berada di kaki Gunung Banyak, Pujon — udara sejuk dan suasana yang menenangkan hati.',
    delay: 'delay-400',
  },
];
---

<section id="why-us" class="py-16 md:py-24 bg-cream">
  <div class="container mx-auto px-6 max-w-7xl">
    <SectionHeading
      eyebrow="Nilai Inti Kami"
      title="Mengapa Memilih Ribath Al-Hadi?"
      subtitle="Pesantren tahfidz khusus putri yang memadukan hafalan mutqin, akhlak Qur’ani, dan kemandirian dalam lingkungan yang menenangkan."
      class="mb-16 md:mb-20"
    />

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {
        features.map((feature) => (
          <div
            class:list={[
              'group bg-white p-8 lg:p-10 rounded-2xl shadow-sm hover:shadow-premium-hover transition-all duration-300 border border-transparent hover:border-primary/10 reveal',
              feature.delay,
            ]}
          >
            <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-6 md:mb-8 group-hover:bg-primary group-hover:text-white transition-colors duration-300">
              <feature.icon class="w-7 h-7" stroke-width={1.5} />
            </div>
            <h3 class="text-xl font-serif text-dark font-medium mb-3 md:mb-4">{feature.title}</h3>
            <p class="text-accent text-sm leading-relaxed">{feature.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
