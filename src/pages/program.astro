---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import {
  ArrowRight,
  BookOpenText,
  HeartHandshake,
  MoonStar,
  BookMarked,
  Clock,
} from '@lucide/astro';
import { PROGRAMS, PILLARS, SCHEDULE, MATERI_DINIYAH } from '../data/content';

// Peta ikon untuk PILLARS (string lucide-name → komponen)
const ICONS = {
  BookOpenText,
  HeartHandshake,
  MoonStar,
};

const delays = ['delay-100', 'delay-200', 'delay-300'];
---

<Layout
  title="Program & Kurikulum - Ribath Al-Hadi"
  description="Program tahfidz, dirosah diniyah, dan pembinaan akhlak di Ribath Al-Hadi — kurikulum terbimbing dengan jadwal harian yang tertata."
>
  <Navbar />
  <WhatsAppFloat />
  <PageHero
    current="Program"
    eyebrow="Kurikulum"
    title="Program & Kurikulum"
    subtitle="Memadukan hafalan Al-Qur’an yang mutqin, kedalaman ilmu diniyah, dan pembinaan akhlak dalam satu sistem pembinaan yang terbimbing."
    image="/images/gallery/kelas-tahfidz.webp"
  />

  <!-- 1. Program Unggulan -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6 max-w-7xl">
      <SectionHeading
        eyebrow="Program Unggulan"
        title="Tiga Fokus Pembinaan Santri"
        subtitle="Setiap santri dibimbing menyeimbangkan hafalan, ilmu, dan akhlak sepanjang masa mondoknya."
        class="mb-16 md:mb-20"
      />

      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        {
          PROGRAMS.map((program, i) => (
            <div
              class:list={[
                'group bg-cream rounded-[2rem] overflow-hidden shadow-sm hover:shadow-premium transition-all duration-300 reveal',
                delays[i] ?? '',
              ]}
            >
              <div class="aspect-video relative overflow-hidden bg-gray-200">
                <img
                  src={program.img}
                  loading="lazy"
                  decoding="async"
                  alt={program.title}
                  title={program.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-dark/60 to-transparent opacity-60" />
              </div>
              <div class="p-6 md:p-8">
                <h3 class="text-xl md:text-2xl font-serif text-dark mb-3">{program.title}</h3>
                <p class="text-accent text-sm leading-relaxed">{program.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 2. Tiga Pilar Keunggulan -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="container mx-auto px-6 max-w-7xl">
      <SectionHeading
        eyebrow="Keunggulan"
        title="Tiga Pilar Keunggulan"
        subtitle="Fondasi yang menjadikan setiap hafalan tertanam kuat dan berbuah akhlak mulia."
        class="mb-16 md:mb-20"
      />

      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        {
          PILLARS.map((pillar, i) => {
            const Icon = ICONS[pillar.icon as keyof typeof ICONS];
            return (
              <div
                class:list={[
                  'group bg-white p-8 lg:p-10 rounded-3xl shadow-sm hover:shadow-premium-hover transition-all duration-300 border border-transparent hover:border-primary/10 reveal',
                  delays[i] ?? '',
                ]}
              >
                <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-6 md:mb-8 group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                  {Icon && <Icon class="w-7 h-7" stroke-width={1.5} />}
                </div>
                <h3 class="text-xl font-serif text-dark font-medium mb-3 md:mb-4">{pillar.title}</h3>
                <p class="text-accent text-sm leading-relaxed">{pillar.desc}</p>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- 3. Materi Diniyah -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6 max-w-7xl">
      <SectionHeading
        eyebrow="Dirosah Diniyah"
        title="Materi Diniyah"
        subtitle="Bekal ilmu syar’i yang diajarkan secara berjenjang untuk menyempurnakan pemahaman santri."
        class="mb-16 md:mb-20"
      />

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
        {
          MATERI_DINIYAH.map((materi, i) => (
            <div
              class:list={[
                'flex items-center gap-4 bg-cream rounded-2xl p-5 md:p-6 hover:shadow-premium transition-all duration-300 reveal',
                delays[i % 3] ?? '',
              ]}
            >
              <div class="w-11 h-11 shrink-0 bg-primary/10 rounded-xl flex items-center justify-center text-primary">
                <BookMarked class="w-5 h-5" stroke-width={1.5} />
              </div>
              <span class="font-serif text-dark text-base md:text-lg">{materi}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 4. Jadwal Harian -->
  <section class="py-16 md:py-24 bg-dark text-white">
    <div class="container mx-auto px-6 max-w-5xl">
      <SectionHeading
        eyebrow="Rutinitas"
        title="Jadwal Harian Santri"
        subtitle="Hari santri tersusun rapi dari sepertiga malam hingga diniyah malam — menyeimbangkan ruhani, hafalan, dan ilmu."
        align="center"
        invert={true}
        class="mb-16 md:mb-20"
      />

      <div class="space-y-4 md:space-y-5">
        {
          SCHEDULE.map((slot, i) => (
            <div
              class:list={[
                'flex flex-col md:flex-row md:items-center gap-3 md:gap-8 bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-6 md:p-7 hover:bg-white/10 transition-colors reveal',
                delays[i % 3] ?? '',
              ]}
            >
              <div class="flex items-center gap-3 md:w-44 shrink-0">
                <Clock class="w-5 h-5 text-secondary shrink-0" stroke-width={1.5} />
                <span class="font-serif font-bold text-secondary text-base md:text-lg">
                  {slot.time}
                </span>
              </div>
              <div>
                <h3 class="text-lg md:text-xl font-medium text-white mb-1">{slot.title}</h3>
                <p class="text-sm leading-snug text-white/70">{slot.desc}</p>
              </div>
            </div>
          ))
        }
      </div>

      <p class="text-sm text-white/65 italic text-center mt-10 reveal">
        Catatan: jadwal dapat menyesuaikan kebijakan dan agenda pondok.
      </p>
    </div>
  </section>

  <!-- 5. CTA -->
  <section class="py-16 md:py-24 bg-primary-dark text-white">
    <div class="container mx-auto px-6 max-w-4xl text-center reveal">
      <h2 class="text-3xl md:text-5xl font-serif mb-6 leading-tight">
        Siap Menempuh Perjalanan Menghafal Al-Qur’an?
      </h2>
      <p class="text-base md:text-lg text-white/80 mb-10 md:mb-12 max-w-2xl mx-auto">
        Bergabunglah dengan program tahfidz terbimbing Ribath Al-Hadi. Pelajari alur pendaftaran dan
        persyaratannya.
      </p>
      <a
        href="/ppdb"
        title="Pendaftaran Santri Baru (PPDB)"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 md:px-10 md:py-5 text-base md:text-lg font-medium text-primary-dark bg-secondary rounded-full shadow-[0_0_40px_rgba(212,175,55,0.4)] hover:bg-white transition-all duration-300 hover:-translate-y-1"
      >
        Lihat Info PPDB
        <ArrowRight class="w-5 h-5" stroke-width={2} />
      </a>
    </div>
  </section>

  <Footer />
</Layout>
