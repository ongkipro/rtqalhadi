---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { SITE, CONTACT, waLink } from '../data/site';
import { FACILITIES } from '../data/content';
import {
  BedDouble,
  Building2,
  BookOpen,
  Mountain,
  UtensilsCrossed,
  ShieldCheck,
  MapPin,
  ArrowRight,
  MessageCircle,
} from '@lucide/astro';

const ICONS = { BedDouble, Building2, BookOpen, Mountain, UtensilsCrossed, ShieldCheck };

const ENVIRONMENT = [
  { src: '/images/gallery/gedung-asrama-depan.webp', alt: 'Gedung asrama putri tampak depan' },
  { src: '/images/gallery/gedung-asrama-kuning.webp', alt: 'Gedung asrama berwarna kuning di lingkungan pondok' },
  { src: '/images/gallery/gedung-aula-putih.webp', alt: 'Gedung aula putih tempat kegiatan bersama santri' },
  { src: '/images/gallery/taman-kolam.webp', alt: 'Taman dan kolam yang asri di area pondok' },
  { src: '/images/gallery/gerbang-alhadi.webp', alt: 'Gerbang masuk Ribath Al-Hadi' },
  { src: '/images/gallery/halaman-apel-gunung.webp', alt: 'Halaman apel santri dengan latar pegunungan' },
];

const ctaText = `Assalamu’alaikum, saya ingin bertanya tentang fasilitas dan lingkungan ${SITE.name}.`;
---

<Layout
  title="Fasilitas & Lingkungan - Ribath Al-Hadi"
  description="Fasilitas asrama, musholla, dan ruang belajar Ribath Tahfidh Al-Qur'an Al-Hadi di kaki Gunung Banyak, Pujon — Malang. Lingkungan sejuk dan menenangkan untuk menghafal Al-Qur'an."
>
  <Navbar />
  <WhatsAppFloat />

  <PageHero
    current="Fasilitas"
    eyebrow="Fasilitas Premium"
    title="Fasilitas & Lingkungan"
    subtitle="Berada di kaki Gunung Banyak, Pujon — udara yang sejuk dan suasana yang tenang menjadi ruang terbaik bagi putri untuk menghafal Al-Qur'an dengan hati dan jiwa."
    image="/images/gallery/gedung-asrama-depan.webp"
  />

  <!-- 1) Fasilitas (grid kartu ikon) -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="container mx-auto px-6 max-w-7xl">
      <SectionHeading
        eyebrow="Fasilitas Pondok"
        title="Penunjang Ibadah & Belajar"
        subtitle="Sarana yang mendukung kenyamanan santri dalam menghafal, beribadah, dan menjalani keseharian di asrama."
        class="mb-12 md:mb-16"
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 md:gap-8">
        {
          FACILITIES.map((f) => {
            const Icon = ICONS[f.icon as keyof typeof ICONS];
            return (
              <div class="bg-white p-6 md:p-8 rounded-[2rem] text-center border border-transparent hover:border-primary/20 hover:shadow-premium transition-all duration-300 group reveal">
                <div class="w-14 h-14 md:w-16 md:h-16 mx-auto bg-primary/5 rounded-2xl flex items-center justify-center text-primary mb-5 md:mb-6 group-hover:scale-110 transition-transform">
                  <Icon class="w-7 h-7 md:w-8 md:h-8" stroke-width={1.5} />
                </div>
                <h3 class="font-serif text-lg md:text-xl text-dark mb-2">{f.title}</h3>
                <p class="text-sm text-accent">{f.desc}</p>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- 2) Lingkungan Pondok (galeri foto bangunan & lingkungan) -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6 max-w-7xl">
      <SectionHeading
        eyebrow="Lingkungan Pondok"
        title="Suasana Asri Penuh Ketenangan"
        subtitle="Bangunan asrama, aula, taman, dan halaman yang berpadu dengan kesejukan alam pegunungan."
        class="mb-12 md:mb-16"
      />

      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-5">
        {
          ENVIRONMENT.map((img) => (
            <div class="relative overflow-hidden rounded-2xl md:rounded-3xl shadow-premium group reveal">
              <img
                src={img.src}
                alt={img.alt}
                title={img.alt}
                loading="lazy"
                decoding="async"
                class="w-full h-48 md:h-64 object-cover transition-transform duration-500 group-hover:scale-110"
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 3) Catatan lokasi -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="relative overflow-hidden rounded-[2rem] shadow-premium reveal">
          <img
            src="/images/gallery/halaman-apel-gunung.webp"
            alt="Halaman pondok dengan latar Gunung Banyak"
            title="Halaman pondok dengan latar Gunung Banyak"
            loading="lazy"
            decoding="async"
            class="w-full h-72 md:h-96 object-cover"
          />
        </div>
        <div class="reveal">
          <span class="text-secondary font-medium tracking-widest uppercase text-sm mb-4 block">Lokasi</span>
          <h2 class="text-3xl md:text-4xl font-serif text-dark mb-6 leading-tight">Di Kaki Gunung Banyak, Pujon</h2>
          <p class="text-accent mb-5">
            {SITE.name} berada di Dsn. Krajan, Pandesari, Kecamatan Pujon, Kabupaten Malang — tepat di kaki Gunung
            Banyak. Udara yang sejuk dan suasana pegunungan yang tenang menjadikannya lingkungan yang ideal untuk
            menghafal Al-Qur'an dengan khusyuk.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3 text-accent">
              <MapPin class="w-5 h-5 text-primary shrink-0 mt-0.5" stroke-width={1.5} />
              <span>Kawasan sejuk di kaki Gunung Banyak, Pujon — Kabupaten Malang.</span>
            </li>
            <li class="flex items-start gap-3 text-accent">
              <MapPin class="w-5 h-5 text-primary shrink-0 mt-0.5" stroke-width={1.5} />
              <span>Mudah dijangkau, dekat dengan jalan raya jalur Malang–Kediri/Jombang.</span>
            </li>
            <li class="flex items-start gap-3 text-accent">
              <MapPin class="w-5 h-5 text-primary shrink-0 mt-0.5" stroke-width={1.5} />
              <span>Bagian dari keluarga besar Ma'had Nurul Haromain (cabang ke-66).</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 4) CTA band -->
  <section class="py-16 md:py-24 bg-primary">
    <div class="container mx-auto px-6 max-w-4xl text-center reveal">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif text-white mb-6 leading-tight">
        Ingin Melihat Langsung Lingkungan Pondok?
      </h2>
      <p class="text-base md:text-lg text-white/80 mb-10">
        Jadilah bagian dari keluarga besar Al-Hadi. Daftarkan putri Anda atau tanyakan informasi fasilitas dan
        pendaftaran kepada kami.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/ppdb"
          title="Pendaftaran Santri Baru (PPDB)"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 md:px-10 md:py-5 text-base md:text-lg font-medium text-primary-dark bg-secondary rounded-full shadow-[0_0_40px_rgba(212,175,55,0.4)] hover:bg-white transition-all duration-300 hover:-translate-y-1"
        >
          Daftar PPDB
          <ArrowRight class="w-5 h-5" stroke-width={2} />
        </a>
        <a
          href={waLink(CONTACT.waPendaftaran.number, ctaText)}
          target="_blank"
          rel="noopener noreferrer"
          title="Hubungi via WhatsApp"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 md:px-10 md:py-5 text-base md:text-lg font-medium text-white bg-green-600 rounded-full shadow-lg hover:bg-green-500 transition-all duration-300 hover:-translate-y-1"
        >
          <MessageCircle class="w-6 h-6" stroke-width={1.5} />
          Tanya via WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
