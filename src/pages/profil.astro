---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import QuranVerse from '../components/QuranVerse.astro';
import { AYAT_HIFDH } from '../data/quotes';
import { ArrowRight, CircleCheckBig, Quote } from '@lucide/astro';
import { SITE, ADDRESS, CONTACT, waLink } from '../data/site';
import { STATS } from '../data/content';

const mottoCards = [
  {
    title: 'Jujur',
    desc: 'Menanamkan kejujuran dalam niat, ucapan, dan amal — pondasi seorang penghafal Al-Qur’an.',
  },
  {
    title: 'Ikhlas',
    desc: 'Meluruskan setiap langkah hanya untuk meraih ridha Allah, bukan pujian sesama.',
  },
  {
    title: 'Semangat',
    desc: 'Memelihara ghirah belajar dan menghafal yang tak pernah padam dalam suka maupun lelah.',
  },
];

const misi = [
  'Menyelenggarakan program tahfidz bin nadhri & bil hifdhi secara intensif dan terbimbing.',
  'Menanamkan akhlaqul karimah dan pembiasaan ibadah (qiyamullail, muroja’ah, murottal).',
  'Membekali santri ilmu diniyah (Attibyan, Nahwu-Shorof, Tahsin, Hadits, Fiqih, Aqidah).',
  'Membangun lingkungan asrama yang disiplin, aman, dan kondusif bagi para putri.',
];

const visi =
  'Membentuk generasi hafidzah berakhlak Qur’ani yang jujur, ikhlas, dan bersemangat dalam menjaga serta mengamalkan Al-Qur’an.';

const waPesan = waLink(
  CONTACT.waPendaftaran.number,
  'Assalamu’alaikum, saya ingin mengetahui lebih lanjut tentang Ribath Tahfidh Al-Qur’an Al-Hadi dan proses pendaftarannya.'
);
---

<Layout
  title="Profil - Ribath Al-Hadi"
  description="Mengenal Ribath Tahfidh Al-Qur’an Al-Hadi — pesantren tahfidz khusus putri di kaki Gunung Banyak, Pujon, Malang, cabang ke-66 Ma’had Nurul Haromain."
>
  <Navbar />
  <WhatsAppFloat />
  <PageHero
    current="Profil"
    eyebrow="Tentang Kami"
    title="Profil Ribath Al-Hadi"
    subtitle={SITE.tagline}
    image="/images/gallery/gerbang-alhadi.webp"
  />

  <!-- 1. Sekilas -->
  <section class="py-16 md:py-24 bg-white overflow-hidden">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="relative order-2 lg:order-1 reveal">
          <div class="absolute inset-0 bg-primary/5 rounded-2xl transform -rotate-3 scale-105"></div>
          <img
            src="/images/gallery/halaqah-santri.webp"
            loading="lazy"
            decoding="async"
            alt="Halaqah santri Ribath Al-Hadi"
            title="Halaqah santri Ribath Al-Hadi"
            class="relative rounded-2xl shadow-premium w-full h-[350px] md:h-[450px] lg:h-[560px] object-cover object-center"
          />
        </div>

        <div class="max-w-xl order-1 lg:order-2 reveal">
          <span class="text-secondary font-medium tracking-widest uppercase text-sm mb-4 block"
            >Sekilas Kami</span
          >
          <h2 class="text-3xl md:text-5xl font-serif text-dark mb-6 md:mb-8 leading-tight">
            Sekilas Ribath Al-Hadi
          </h2>
          <div class="space-y-5 text-base md:text-lg text-accent leading-relaxed">
            <p>
              <strong class="text-dark">{SITE.name}</strong> adalah pesantren tahfidz khusus putri yang
              berdiri sejak tahun {SITE.est}. Sebagai bagian dari keluarga besar{' '}
              {SITE.induk} — tercatat sebagai cabang ke-66 — Al-Hadi mengusung tradisi keilmuan dan
              pembinaan ruhani yang telah teruji.
            </p>
            <p>
              Pondok ini berdiri di {ADDRESS.building}, tepat di kaki Gunung Banyak. Udara
              pegunungan yang sejuk dan suasana yang tenang menjadikannya tempat yang ideal bagi para
              putri untuk fokus menghafal Al-Qur’an.
            </p>
            <p>
              Dengan sistem boarding (asrama) penuh 24 jam, santri tumbuh dalam lingkungan yang aman,
              terjaga, dan disiplin. Sejak berdiri, Al-Hadi telah melahirkan banyak hafidzah yang siap
              menjaga dan mengamalkan Al-Qur’an di tengah masyarakat.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Stats strip -->
  <section class="py-16 md:py-20 bg-primary text-white">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10 text-center reveal">
        {
          STATS.map((stat) => (
            <div>
              <p class="text-4xl md:text-5xl font-serif text-secondary mb-2">{stat.value}</p>
              <p class="text-sm md:text-base text-white/70">{stat.label}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 3. Motto -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="container mx-auto px-6 max-w-7xl">
      <SectionHeading
        eyebrow="Nilai yang Kami Pegang"
        title="Motto Kami"
        subtitle="Tiga kata yang menjadi ruh setiap kegiatan dan langkah santri Al-Hadi."
        class="mb-16 md:mb-20"
      />
      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        {
          mottoCards.map((m, i) => (
            <div
              class:list={[
                'group bg-white p-8 lg:p-10 rounded-2xl shadow-sm hover:shadow-premium-hover transition-all duration-300 border border-transparent hover:border-primary/10 text-center reveal',
                ['delay-100', 'delay-200', 'delay-300'][i],
              ]}
            >
              <div class="w-14 h-14 mx-auto bg-secondary/15 rounded-2xl flex items-center justify-center text-secondary font-serif text-2xl mb-6">
                {i + 1}
              </div>
              <h3 class="text-2xl font-serif text-primary mb-3">{m.title}</h3>
              <p class="text-accent text-sm leading-relaxed">{m.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 4. Visi & Misi -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6 max-w-7xl">
      <SectionHeading
        eyebrow="Arah & Tujuan"
        title="Visi & Misi"
        subtitle="Cita-cita besar yang kami terjemahkan ke dalam langkah-langkah pembinaan nyata."
        class="mb-16 md:mb-20"
      />

      <div class="grid lg:grid-cols-2 gap-8 md:gap-10">
        <div class="bg-primary text-white rounded-2xl p-8 md:p-12 shadow-premium reveal">
          <span class="text-secondary font-medium tracking-widest uppercase text-sm mb-5 block"
            >Visi</span
          >
          <p class="text-xl md:text-2xl font-serif leading-relaxed">{visi}</p>
        </div>

        <div class="bg-cream rounded-2xl p-8 md:p-12 reveal delay-100">
          <span class="text-secondary font-medium tracking-widest uppercase text-sm mb-6 block"
            >Misi</span
          >
          <ul class="space-y-5">
            {
              misi.map((item) => (
                <li class="flex items-start gap-3">
                  <CircleCheckBig class="w-6 h-6 text-primary shrink-0 mt-0.5" stroke-width={1.5} />
                  <span class="text-accent leading-relaxed">{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <p class="text-sm text-accent/80 italic text-center mt-10 reveal">
        Catatan: rumusan visi-misi ini masih terus disempurnakan bersama pengasuh dan pengurus
        pondok.
      </p>
    </div>
  </section>

  <!-- Ayat: penjagaan Al-Qur'an -->
  <QuranVerse verse={AYAT_HIFDH} />

  <!-- 5. Naungan & Sanad -->
  <section class="py-16 md:py-24 bg-cream overflow-hidden">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="max-w-xl reveal">
          <span class="text-secondary font-medium tracking-widest uppercase text-sm mb-4 block"
            >Naungan & Sanad</span
          >
          <h2 class="text-3xl md:text-5xl font-serif text-dark mb-6 md:mb-8 leading-tight">
            Di Bawah Naungan Nurul Haromain
          </h2>
          <div class="space-y-5 text-base md:text-lg text-accent leading-relaxed">
            <p>
              Ribath Al-Hadi berada di bawah naungan {SITE.induk} Pujon, sebuah lembaga dakwah dan
              pendidikan yang telah dipercaya membina ribuan santri.
            </p>
            <p>
              Pondok ini diasuh oleh <strong class="text-dark">KH Ihya’ Ulumiddin</strong>, murid
              langsung Abuya Dr. Sayyid Muhammad bin Alawi Al-Maliki Al-Hasani dari Makkah. Sanad
              keilmuan inilah yang menjaga keaslian tradisi dan keberkahan ilmu di Al-Hadi.
            </p>
          </div>

          <blockquote class="mt-8 md:mt-10 pl-5 md:pl-6 border-l-4 border-secondary py-2">
            <Quote class="w-6 h-6 text-secondary mb-3" stroke-width={1.5} />
            <p
              dir="rtl"
              lang="ar"
              class="font-arabic text-3xl md:text-4xl text-primary leading-loose text-left mb-3"
            >
              مَا زِلْتَ طَالِبًا
            </p>
            <p class="text-lg md:text-xl font-serif text-primary italic">
              “Selamanya Kamu Adalah Santri.”
            </p>
            <footer class="text-xs md:text-sm text-accent mt-3">— Motto Ma’had Nurul Haromain</footer>
          </blockquote>
        </div>

        <div class="relative reveal delay-100">
          <div class="absolute inset-0 bg-primary/5 rounded-2xl transform rotate-3 scale-105"></div>
          <img
            src="/images/gallery/pengasuh-bersama-santri.webp"
            loading="lazy"
            decoding="async"
            alt="Pengasuh bersama santri Ribath Al-Hadi"
            title="Pengasuh bersama santri Ribath Al-Hadi"
            class="relative rounded-2xl shadow-premium w-full h-[350px] md:h-[450px] lg:h-[560px] object-cover object-center"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CTA -->
  <section class="py-16 md:py-24 bg-primary-dark text-white">
    <div class="container mx-auto px-6 max-w-4xl text-center reveal">
      <h2 class="text-3xl md:text-5xl font-serif mb-6 leading-tight">
        Jadikan Putri Anda Bagian dari Keluarga Al-Hadi
      </h2>
      <p class="text-base md:text-lg text-white/80 mb-10 md:mb-12 max-w-2xl mx-auto">
        Mulai langkah pertama menuju masa depan Qur’ani. Kuota terbatas demi menjaga kualitas
        bimbingan setiap santri.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/ppdb"
          title="Pendaftaran Santri Baru (PPDB)"
          class="w-full sm:w-auto px-8 py-4 md:px-10 md:py-5 text-base md:text-lg font-medium text-primary-dark bg-secondary rounded-full shadow-[0_0_40px_rgba(212,175,55,0.4)] hover:bg-white transition-all duration-300 hover:-translate-y-1 inline-flex items-center justify-center gap-2"
        >
          Info PPDB
          <ArrowRight class="w-5 h-5" stroke-width={2} />
        </a>
        <a
          href={waPesan}
          target="_blank"
          rel="noopener noreferrer"
          title="Hubungi via WhatsApp"
          class="w-full sm:w-auto px-8 py-4 md:px-10 md:py-5 text-base md:text-lg font-medium text-white border border-white/30 rounded-full hover:bg-white/10 transition-all duration-300 hover:-translate-y-1 inline-flex items-center justify-center gap-2"
        >
          Tanya via WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
