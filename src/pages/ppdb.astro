---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { SITE, ADDRESS, CONTACT, waLink } from '../data/site';
import { PPDB_STEPS, PPDB_REQUIREMENTS } from '../data/content';
import {
  Users,
  UserRound,
  GraduationCap,
  CircleCheckBig,
  MapPin,
  MessageCircle,
  QrCode,
  Phone,
} from '@lucide/astro';

const infoCards = [
  {
    icon: Users,
    title: 'Kuota Terbatas',
    desc: 'Jumlah penerimaan dibatasi setiap tahun demi menjaga kualitas bimbingan tahfidz.',
  },
  {
    icon: UserRound,
    title: 'Khusus Putri',
    desc: 'Lingkungan asrama (boarding) penuh khusus putri yang aman dan terjaga.',
  },
  {
    icon: GraduationCap,
    title: 'Lulusan setingkat SMP',
    desc: 'Diperuntukkan bagi putri lulusan setingkat SMP yang siap mondok.',
  },
];

const waDaftarUrl = waLink(
  CONTACT.waPendaftaran.number,
  'Assalamualaikum, saya ingin mendaftar PPDB Ribath Al-Hadi. Mohon informasinya.'
);
const waTanyaUrl = waLink(
  CONTACT.waPIC.number,
  'Assalamualaikum, saya ingin bertanya seputar PPDB Ribath Al-Hadi.'
);
---

<Layout
  title="PPDB - Ribath Al-Hadi"
  description="Penerimaan Peserta Didik Baru Ribath Tahfidh Al-Qur'an Al-Hadi — pesantren tahfidz khusus putri di Pujon, Malang. Kuota terbatas, lulusan setingkat SMP."
>
  <Navbar />
  <WhatsAppFloat />
  <PageHero
    current="PPDB"
    eyebrow="Penerimaan Santri Baru"
    title="Penerimaan Peserta Didik Baru"
    subtitle="Kuota terbatas — khusus putri lulusan setingkat SMP. Bergabunglah dengan keluarga besar Ribath Al-Hadi."
    image="/images/gallery/apel-santri-seragam.webp"
  />

  <!-- 1) Info cards -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {
          infoCards.map((card, i) => (
            <div
              class:list={[
                'bg-cream p-6 md:p-8 rounded-[2rem] text-center border border-transparent hover:border-primary/20 hover:shadow-premium transition-all duration-300 group reveal',
                `delay-${(i + 1) * 100}`,
              ]}
            >
              <div class="w-14 h-14 md:w-16 md:h-16 mx-auto bg-primary/5 rounded-2xl flex items-center justify-center text-primary mb-5 md:mb-6 group-hover:scale-110 transition-transform">
                <card.icon class="w-7 h-7 md:w-8 md:h-8" stroke-width={1.5} />
              </div>
              <h3 class="font-serif text-lg md:text-xl text-dark mb-2">{card.title}</h3>
              <p class="text-sm text-accent">{card.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 2) Alur Pendaftaran -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="container mx-auto px-6 max-w-5xl">
      <SectionHeading
        eyebrow="Langkah Demi Langkah"
        title="Alur Pendaftaran"
        subtitle="Empat tahapan sederhana untuk menjadi bagian dari keluarga besar Ribath Al-Hadi."
        class="mb-16"
      />

      <div class="grid md:grid-cols-4 gap-8 md:gap-4 relative z-0">
        <!-- Connecting Line for Desktop -->
        <div class="hidden md:block absolute top-10 left-16 right-16 h-0.5 bg-gray-200 z-[-1]"></div>
        <!-- Connecting Line for Mobile -->
        <div
          class="md:hidden absolute top-10 bottom-10 left-1/2 transform -translate-x-1/2 w-0.5 bg-gray-200 z-[-1]"
        >
        </div>

        {
          PPDB_STEPS.map((step, i) => (
            <div class:list={['relative z-10 text-center reveal', `delay-${(i + 1) * 100}`]}>
              <div
                class:list={[
                  'w-16 h-16 md:w-20 md:h-20 mx-auto rounded-full flex items-center justify-center text-xl md:text-2xl font-serif font-bold mb-4 md:mb-6 ring-8 ring-cream',
                  i === 0
                    ? 'bg-primary text-white shadow-lg'
                    : 'bg-white border-2 border-primary text-primary',
                ]}
              >
                {step.num}
              </div>
              <h3 class="font-bold text-dark mb-2">{step.title}</h3>
              <p class="text-sm text-accent max-w-[220px] mx-auto md:max-w-none">{step.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 3) Persyaratan Pendaftaran -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6 max-w-5xl">
      <SectionHeading
        eyebrow="Berkas Administrasi"
        title="Persyaratan Pendaftaran"
        subtitle="Siapkan dokumen berikut untuk melengkapi proses pendaftaran calon santri."
        class="mb-12 md:mb-16"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
        {
          PPDB_REQUIREMENTS.map((req) => (
            <div class="flex items-start gap-4 bg-cream p-5 rounded-2xl border border-transparent hover:border-primary/20 transition-colors reveal">
              <CircleCheckBig class="w-6 h-6 text-primary shrink-0 mt-0.5" stroke-width={1.5} />
              <p class="text-sm md:text-base text-dark">{req}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 4) Cara Mendaftar -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="container mx-auto px-6 max-w-6xl">
      <SectionHeading
        eyebrow="Dua Pilihan Mudah"
        title="Cara Mendaftar"
        subtitle="Daftar secara langsung (offline) atau melalui WhatsApp (online)."
        class="mb-12 md:mb-16"
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <!-- Offline -->
        <div class="bg-white p-8 md:p-10 rounded-[2rem] shadow-premium reveal delay-100">
          <div
            class="w-14 h-14 md:w-16 md:h-16 bg-primary/5 rounded-2xl flex items-center justify-center text-primary mb-6"
          >
            <MapPin class="w-7 h-7 md:w-8 md:h-8" stroke-width={1.5} />
          </div>
          <span class="text-secondary font-medium tracking-widest uppercase text-xs mb-2 block"
            >Offline</span
          >
          <h3 class="font-serif text-xl md:text-2xl text-dark mb-4">Datang Langsung</h3>
          <p class="text-accent text-sm md:text-base mb-4">
            Datang langsung ke tempat pendaftaran LPI Nurul Haromain untuk membeli formulir dan
            menyerahkan berkas:
          </p>
          <p class="text-dark text-sm md:text-base font-medium leading-relaxed">
            {ADDRESS.mailing}
          </p>
        </div>

        <!-- Online -->
        <div class="bg-white p-8 md:p-10 rounded-[2rem] shadow-premium reveal delay-200">
          <div
            class="w-14 h-14 md:w-16 md:h-16 bg-primary/5 rounded-2xl flex items-center justify-center text-primary mb-6"
          >
            <MessageCircle class="w-7 h-7 md:w-8 md:h-8" stroke-width={1.5} />
          </div>
          <span class="text-secondary font-medium tracking-widest uppercase text-xs mb-2 block"
            >Online</span
          >
          <h3 class="font-serif text-xl md:text-2xl text-dark mb-4">WhatsApp / Scan QR</h3>
          <p class="text-accent text-sm md:text-base mb-6">
            Kirim pesan WhatsApp ke <span class="text-dark font-medium"
              >{CONTACT.waPendaftaran.display}</span
            > ({CONTACT.waPendaftaran.label}), atau scan QR code yang tertera pada brosur resmi.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href={waDaftarUrl}
              target="_blank"
              rel="noopener noreferrer"
              title="Hubungi via WhatsApp"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-medium text-white bg-primary rounded-full shadow-lg hover:bg-primary-dark transition-all duration-300 hover:-translate-y-0.5"
            >
              <MessageCircle class="w-5 h-5" stroke-width={1.5} />
              Chat Pendaftaran
            </a>
            <span
              class="inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-medium text-primary bg-primary/5 rounded-full"
            >
              <QrCode class="w-5 h-5" stroke-width={1.5} />
              Scan QR pada brosur
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5) CTA Band -->
  <section class="py-16 md:py-24 bg-primary">
    <div class="container mx-auto px-6 max-w-4xl text-center reveal">
      <h2 class="text-3xl md:text-5xl font-serif text-white mb-5 md:mb-6 leading-tight">
        Daftar Sekarang via WhatsApp
      </h2>
      <p class="text-base md:text-lg text-white/80 mb-10 max-w-2xl mx-auto">
        Kuota terbatas. Amankan tempat putri Anda di {SITE.name} ({SITE.cabang}). Hubungi panitia
        pendaftaran untuk informasi lengkap.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={waDaftarUrl}
          target="_blank"
          rel="noopener noreferrer"
          title="Hubungi via WhatsApp"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 md:px-10 md:py-5 text-base md:text-lg font-medium text-primary-dark bg-secondary rounded-full shadow-[0_0_40px_rgba(212,175,55,0.4)] hover:bg-white transition-all duration-300 hover:-translate-y-1"
        >
          <MessageCircle class="w-6 h-6" stroke-width={1.5} />
          Daftar via {CONTACT.waPendaftaran.label}
        </a>
        <a
          href={waTanyaUrl}
          target="_blank"
          rel="noopener noreferrer"
          title="Hubungi via WhatsApp"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 md:px-10 md:py-5 text-base md:text-lg font-medium text-white border border-white/40 rounded-full hover:bg-white/10 transition-all duration-300 hover:-translate-y-1"
        >
          <Phone class="w-6 h-6" stroke-width={1.5} />
          Tanya ke {CONTACT.waPIC.label}
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
