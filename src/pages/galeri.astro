---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { SITE, CONTACT } from '../data/site';
import { GALLERY } from '../data/content';
import { AtSign } from '@lucide/astro';

// Pola span untuk kesan masonry yang dinamis namun tetap rapi.
const SPANS = [
  'md:col-span-2 md:row-span-2',
  '',
  '',
  'md:row-span-2',
  '',
  'md:col-span-2',
  '',
  '',
  'md:col-span-2',
  '',
  'md:row-span-2',
  '',
];
---

<Layout
  title="Galeri Kegiatan - Ribath Al-Hadi"
  description="Dokumentasi momen tahfidz, halaqah, kegiatan, dan kehidupan santri Ribath Tahfidh Al-Qur'an Al-Hadi, Pujon — Malang."
>
  <Navbar />
  <WhatsAppFloat />

  <PageHero
    current="Galeri"
    eyebrow="Dokumentasi"
    title="Galeri Kegiatan"
    subtitle="Sekilas momen tahfidz, halaqah, kegiatan, dan keseharian santri di lingkungan Ribath Al-Hadi."
    image="/images/gallery/foto-bersama-santri-02.webp"
  />

  <!-- 1) Galeri masonry -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6 max-w-7xl">
      <SectionHeading
        eyebrow="Album Kegiatan"
        title="Jejak Keseharian Santri"
        subtitle="Dari setoran hafalan hingga rihlah — potret kehidupan di Ribath Al-Hadi."
        class="mb-12 md:mb-16"
      />

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4 auto-rows-[180px]">
        {
          GALLERY.map((img, i) => (
            <figure
              class:list={[
                'relative overflow-hidden rounded-2xl md:rounded-3xl shadow-premium group reveal',
                SPANS[i] ?? '',
              ]}
            >
              <img
                src={img.src}
                alt={img.alt}
                title={img.alt}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              />
              <figcaption class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-dark/85 via-dark/40 to-transparent text-white text-sm font-light translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                {img.alt}
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 2) CTA Instagram -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="container mx-auto px-6 max-w-3xl text-center reveal">
      <div class="w-16 h-16 mx-auto bg-primary/5 rounded-2xl flex items-center justify-center text-primary mb-6">
        <AtSign class="w-8 h-8" stroke-width={1.5} />
      </div>
      <h2 class="text-3xl md:text-4xl font-serif text-dark mb-5 leading-tight">
        Ikuti Keseharian Kami di Instagram
      </h2>
      <p class="text-accent mb-10">
        Lihat lebih banyak momen, kegiatan, dan kabar terbaru dari {SITE.name} melalui akun resmi
        <span class="text-primary font-medium">@ribathalhadi</span>.
      </p>
      <a
        href={CONTACT.instagram}
        target="_blank"
        rel="noopener noreferrer"
        title="Instagram @ribathalhadi"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 md:px-10 md:py-5 text-base md:text-lg font-medium text-white bg-primary rounded-full shadow-premium hover:bg-primary-dark transition-all duration-300 hover:-translate-y-1"
      >
        <AtSign class="w-6 h-6" stroke-width={1.5} />
        @ribathalhadi
      </a>
    </div>
  </section>

  <Footer />
</Layout>
