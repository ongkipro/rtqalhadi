---
import '../styles/global.css';
// Font self-host (variable) — hilangkan render-blocking Google Fonts.
import '@fontsource-variable/inter';
import '@fontsource-variable/playfair-display';
import '@fontsource-variable/playfair-display/wght-italic.css';
// Font Arab (subset Arabic) untuk ayat Al-Qur'an & hadits.
import '@fontsource/amiri/arabic-400.css';
import '@fontsource/amiri/arabic-700.css';
import { SITE, ADDRESS, CONTACT, SITE_URL, SEO } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string[];
}

const {
  title = "Ribath Tahfidh Al-Qur'an Al-Hadi - Pesantren Tahfidz Putri Pujon, Malang",
  description = "Ribath Tahfidh Al-Qur'an Al-Hadi (RTQ Al-Hadi) — pesantren tahfidz khusus putri di kaki Gunung Banyak, Pujon, Malang. Bagian dari Ma'had Nurul Haromain (cabang ke-66). Sistem asrama penuh & bimbingan tahfidz intensif.",
  image = '/images/gallery/papan-nama-alhadi.webp',
  keywords = [],
} = Astro.props;

const base = Astro.site ?? new URL(SITE_URL);
const canonical = new URL(Astro.url.pathname, base).href;
const ogImage = new URL(image, base).href;
const keywordsStr = [...keywords, ...SEO.keywords].join(', ');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'EducationalOrganization',
  name: SITE.name,
  alternateName: 'RTQ Al-Hadi',
  url: SITE_URL,
  logo: new URL('/images/gallery/papan-nama-alhadi.webp', base).href,
  image: ogImage,
  description,
  foundingDate: String(SITE.est),
  slogan: SITE.motto.join(', '),
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Jurangrejo, Pandesari',
    addressLocality: 'Pujon',
    addressRegion: 'Jawa Timur',
    postalCode: '65391',
    addressCountry: 'ID',
  },
  geo: { '@type': 'GeoCoordinates', latitude: ADDRESS.coords.lat, longitude: ADDRESS.coords.lng },
  telephone: '+' + CONTACT.waPendaftaran.number,
  sameAs: [CONTACT.instagram, CONTACT.threads, CONTACT.facebook],
  keywords: SEO.keywords.join(', '),
  parentOrganization: { '@type': 'EducationalOrganization', name: SITE.induk },
  publisher: { '@type': 'Organization', name: SEO.publisher, url: 'https://nurulharomain.org' },
  author: { '@type': 'Organization', name: SEO.author, url: SITE_URL },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.7',
    reviewCount: SITE.rating.count,
  },
};
---

<!doctype html>
<html lang="id" class="scroll-smooth scroll-pt-24 md:scroll-pt-28">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywordsStr} />
    <meta name="author" content={SEO.author} />
    <meta name="publisher" content={SEO.publisher} />
    <meta name="copyright" content={SITE.name} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#065F46" />
    <meta name="geo.region" content="ID-JI" />
    <meta name="geo.placename" content="Pujon, Malang" />
    <meta name="geo.position" content={`${ADDRESS.coords.lat};${ADDRESS.coords.lng}`} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Ribath Tahfidh Al-Qur'an Al-Hadi" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="article:publisher" content={CONTACT.facebook} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Tampilkan konten penuh bila JavaScript dimatikan -->
    <noscript>
      <style>
        .reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>

    <!-- Fonts di-self-host via @fontsource-variable (lihat frontmatter) -->

  </head>
  <body class="font-sans text-accent bg-white antialiased selection:bg-primary selection:text-white">
    <slot />

    <script>
      // 3. FAQ Accordion Logic
      const faqBtns = document.querySelectorAll<HTMLButtonElement>('.faq-btn');
      faqBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          const content = btn.nextElementSibling as HTMLElement | null;
          const icon = btn.querySelector('svg');
          if (!content) return;

          document.querySelectorAll('.faq-content').forEach((otherContent) => {
            if (otherContent !== content && !otherContent.classList.contains('hidden')) {
              otherContent.classList.add('hidden');
              otherContent.previousElementSibling?.querySelector('svg')?.classList.remove('rotate-180');
            }
          });

          content.classList.toggle('hidden');
          icon?.classList.toggle('rotate-180');
        });
      });

      // 4. Scroll Reveal — IntersectionObserver (tanpa layout-query di scroll,
      //    menghindari forced reflow & long task pada main thread).
      const revealEls = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('active');
                obs.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -100px 0px', threshold: 0 },
        );
        revealEls.forEach((el) => io.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add('active'));
      }
    </script>
  </body>
</html>
